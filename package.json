{
	"name": "{{PROJECT_NAME}}",
	"version": "0.31.13",
	"description": "{{PROJECT_DESCRIPTION}}",
	"type": "module",
	"license": "MIT",
	"author": "{{AUTHOR}}",
	"repository": {
		"type": "git",
		"url": "git+https://github.com/{{OWNER}}/{{PROJECT_NAME}}.git"
	},
	"keywords": [],
	"main": "./dist/index.js",
	"types": "./dist/index.d.ts",
	"exports": {
		".": {
			"import": "./dist/index.js",
			"types": "./dist/index.d.ts"
		}
	},
	"files": [
		"dist"
	],
	"engines": {
		"node": ">=22.0.0"
	},
	"scripts": {
		"dev": "echo \"Define your dev server command here\"",
		"build": "tsc --build",
		"start": "node dist/index.js",
		"check": "biome check .",
		"check:fix": "biome check --write .",
		"format": "biome format --write .",
		"lint": "biome lint .",
		"lint:fix": "biome lint --write .",
		"lint:eslint": "eslint .",
		"lint:eslint:fix": "eslint . --fix",
		"test": "vitest run",
		"test:watch": "vitest",
		"test:coverage": "vitest run --coverage",
		"test:ui": "vitest --ui",
		"typecheck": "tsc --noEmit",
		"validate": "npm run typecheck && npm run check && npm run test",
		"knip": "knip",
		"prepare": "husky",
		"init": "bash scripts/init.sh"
	},
	"dependencies": {
		"glob": "^13.0.2"
	},
	"devDependencies": {
		"@biomejs/biome": "^2.0.0",
		"@types/node": "^22.0.0",
		"@typescript-eslint/eslint-plugin": "8.57.1",
		"@vitest/coverage-v8": "^3.0.0",
		"@vitest/ui": "^3.0.0",
		"eslint": "10.0.3",
		"eslint-plugin-perfectionist": "5.6.0",
		"eslint-plugin-unused-imports": "4.4.1",
		"husky": "^9.0.0",
		"knip": "5.86.0",
		"lint-staged": "^15.0.0",
		"pr-prism": "^1.0.5",
		"typescript": "^5.7.0",
		"vitest": "^3.0.0"
	},
	"lint-staged": {
		"*.{ts,tsx,js,jsx,json,css,md}": [
			"biome check --write --no-errors-on-unmatched"
		]
	}
}
