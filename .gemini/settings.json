{
  "mcpServers": {
    "task-master-ai": {
      "command": "npx",
      "args": [
        "-y",
        "task-master-ai"
      ],
      "env": {
        "ANTHROPIC_API_KEY": "YOUR_ANTHROPIC_API_KEY_HERE",
        "PERPLEXITY_API_KEY": "YOUR_PERPLEXITY_API_KEY_HERE",
        "OPENAI_API_KEY": "YOUR_OPENAI_KEY_HERE",
        "GOOGLE_API_KEY": "YOUR_GOOGLE_KEY_HERE",
        "XAI_API_KEY": "YOUR_XAI_KEY_HERE",
        "OPENROUTER_API_KEY": "YOUR_OPENROUTER_KEY_HERE",
        "MISTRAL_API_KEY": "YOUR_MISTRAL_KEY_HERE",
        "AZURE_OPENAI_API_KEY": "YOUR_AZURE_KEY_HERE",
        "OLLAMA_API_KEY": "YOUR_OLLAMA_API_KEY_HERE"
      }
    }
  },
  "context": {
    "fileName": [
      "GEMINI.md"
    ]
  },
  "hooks": {
    "BeforeTool": [
      {
        "matcher": "write_file|replace",
        "hooks": [
          {
            "name": "block-secrets",
            "type": "command",
            "command": "$GEMINI_PROJECT_DIR/.gemini/hooks/block-secrets.sh",
            "description": "Deny file writes that appear to contain secrets or PEM private keys",
            "timeout": 4000
          },
          {
            "name": "dedup-before-write",
            "type": "command",
            "command": "$GEMINI_PROJECT_DIR/.gemini/hooks/dedup-before-write.sh",
            "description": "Before TS/JS writes, deny when the candidate file would duplicate existing repo symbols",
            "timeout": 28000
          }
        ]
      }
    ],
    "AfterTool": [
      {
        "matcher": "write_file|replace",
        "hooks": [
          {
            "name": "dedup-after-write",
            "type": "command",
            "command": "$GEMINI_PROJECT_DIR/.gemini/hooks/dedup-after-write.sh",
            "description": "After TS/JS writes, deny when dedup-check-file finds duplicate/near-duplicate symbols vs repo index",
            "timeout": 28000
          }
        ]
      }
    ],
    "PreCompress": [
      {
        "hooks": [
          {
            "name": "compact-preserve",
            "type": "command",
            "command": "$GEMINI_PROJECT_DIR/.gemini/hooks/pre-compress.sh",
            "description": "Before Gemini compresses history, surface the state that must survive the summary",
            "timeout": 4000
          }
        ]
      }
    ]
  }
}
